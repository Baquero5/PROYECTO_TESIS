# SmartInventory AI - Backend Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3307/TESIS

# Security (generate a strong random key for production)
# SECRET_KEY=your-super-secret-key-here

# Admin default password (only used on first creation)
ADMIN_DEFAULT_PASSWORD=Admin123!

# CORS origins (comma separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Debug mode
DEBUG=false

# ML Models path
MODELS_PATH=ml_models

# Prediction confidence level
PREDICTION_CONFIDENCE_LEVEL=0.95
